<Window x:Class="GantsPlace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="GANDS RESERVATION" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeepBrush}"
        MinWidth="960" MinHeight="620">
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="MainFrame"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── NAVBAR ── -->
        <Border Grid.Row="0" Background="{StaticResource BgNavbarBrush}">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.5" Color="#000000"/>
            </Border.Effect>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + nom -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Images/logo.png" Width="40" Height="40" Margin="0,0,10,0" Stretch="Uniform"/>
                    <TextBlock Text="GANDS RESERVATION" FontFamily="{StaticResource AppFont}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Nav links (centre) -->
                <StackPanel x:Name="NavLinks" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Center">

<Button x:Name="BtnAccueil" ToolTip="Page d'accueil" Style="{StaticResource NavButtonStyle}" Margin="2,0" Click="BtnAccueil_Click">
  <Button.Content>
    <TextBlock>
      <Run Text=""/>
      <Run Text="Accueil"/>
    </TextBlock>
  </Button.Content>
</Button>
<Button x:Name="BtnExplorer" ToolTip="Explorer les salles" Style="{StaticResource NavButtonStyle}" Margin="2,0" Click="BtnExplorer_Click">
  <Button.Content>
    <TextBlock>
      <Run Text=""/>
      <Run Text="Explorer"/>
    </TextBlock>
  </Button.Content>
</Button>
<Button x:Name="BtnHistorique" ToolTip="Historique des réservations" Style="{StaticResource NavButtonStyle}" Margin="2,0" Click="BtnHistorique_Click">
  <Button.Content>
    <TextBlock>
      <Run Text=""/>
      <Run Text="Historique"/>
    </TextBlock>
  </Button.Content>
</Button>
<Button x:Name="BtnAdmin" ToolTip="Administration" Style="{StaticResource NavButtonStyle}" Margin="2,0" Visibility="Collapsed" Click="BtnAdmin_Click">
  <Button.Content>
    <TextBlock>
      <Run Text=""/>
      <Run Text="Admin"/>
    </TextBlock>
  </Button.Content>
</Button>
<Button x:Name="BtnContact" ToolTip="Nous contacter" Style="{StaticResource NavButtonStyle}" Margin="2,0" Click="BtnContact_Click">
  <Button.Content>
    <TextBlock>
      <Run Text=""/>
      <Run Text="Contact"/>
    </TextBlock>
  </Button.Content>
</Button>
                </StackPanel>

                <!-- Auth (droite) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Non connecté -->
                    <StackPanel x:Name="PanelAuth" Orientation="Horizontal">
                        <Button x:Name="BtnConnexion"   Content="Connexion"    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Padding="14,8" Click="BtnConnexion_Click"/>
                        <Button x:Name="BtnInscription" Content="S'inscrire"   Style="{StaticResource PrimaryButtonStyle}"   Padding="14,8"   Click="BtnInscription_Click"/>
                    </StackPanel>
                    <!-- Connecté -->
                    <StackPanel x:Name="PanelUser" Orientation="Horizontal" Visibility="Collapsed">
                        <Border Background="#142045" CornerRadius="20" Padding="12,6" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="24" Height="24" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtUserName" Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="{StaticResource AppFont}" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="BtnDeconnexion" Content="Déconnexion"
                                Style="{StaticResource DangerButtonStyle}" Padding="12,7"
                                Click="BtnDeconnexion_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── CONTENU PRINCIPAL ── -->
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"
               Background="Transparent" Opacity="1"/>
    </Grid>
</Window>
