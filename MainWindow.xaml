<Window x:Class="GantsPlace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GANDS PLACE" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeepBrush}"
        MinWidth="960" MinHeight="620">
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="MainFrame"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── NAVBAR ── -->
        <Border Grid.Row="0" Background="{StaticResource BgNavbarBrush}">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.5" Color="#000000"/>
            </Border.Effect>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + nom -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="8"
                            Width="30" Height="30" Margin="0,0,10,0">
                        <TextBlock Text="G" Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}"/>
                    </Border>
                    <TextBlock Text="GANDS PLACE" FontFamily="{StaticResource AppFont}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Nav links (centre) -->
                <StackPanel x:Name="NavLinks" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button x:Name="BtnAccueil"    Content="Accueil"    Style="{StaticResource NavButtonStyle}" Margin="2,0" Click="BtnAccueil_Click"/>
                    <Button x:Name="BtnExplorer"   Content="Explorer"   Style="{StaticResource NavButtonStyle}" Margin="2,0" Click="BtnExplorer_Click"/>
                    <Button x:Name="BtnHistorique" Content="Historique" Style="{StaticResource NavButtonStyle}" Margin="2,0" Click="BtnHistorique_Click"/>
                    <Button x:Name="BtnContact"    Content="Contact"    Style="{StaticResource NavButtonStyle}" Margin="2,0" Click="BtnContact_Click"/>
                </StackPanel>

                <!-- Auth (droite) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Non connecté -->
                    <StackPanel x:Name="PanelAuth" Orientation="Horizontal">
                        <Button x:Name="BtnConnexion"   Content="Connexion"    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" Padding="14,8" Click="BtnConnexion_Click"/>
                        <Button x:Name="BtnInscription" Content="S'inscrire"   Style="{StaticResource PrimaryButtonStyle}"   Padding="14,8"   Click="BtnInscription_Click"/>
                    </StackPanel>
                    <!-- Connecté -->
                    <StackPanel x:Name="PanelUser" Orientation="Horizontal" Visibility="Collapsed">
                        <Border Background="#142045" CornerRadius="20" Padding="12,6" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="24" Height="24" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtUserName" Foreground="{StaticResource TextPrimaryBrush}"
                                           FontFamily="{StaticResource AppFont}" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="BtnDeconnexion" Content="Déconnexion"
                                Style="{StaticResource DangerButtonStyle}" Padding="12,7"
                                Click="BtnDeconnexion_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── CONTENU PRINCIPAL ── -->
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"
               Background="Transparent" Opacity="1"/>
    </Grid>
</Window>
