<Page x:Class="GantsPlace.Views.AccueilPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgPrimaryBrush}" Title="Accueil">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- HERO -->
            <Grid Height="340">
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0A1428" Offset="0"/>
                            <GradientStop Color="#0D1830" Offset="0.5"/>
                            <GradientStop Color="#091220" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <!-- Glow accent -->
                <Ellipse Width="400" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.06">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#4F8EF7" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Trouvez votre salle idéale"
                               FontFamily="{StaticResource AppFont}" FontSize="34" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Sélectionnez vos critères et réservez en quelques secondes"
                               FontFamily="{StaticResource AppFont}" FontSize="15"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                    <!-- Barre recherche moderne -->
                    <Border Background="White" CornerRadius="16" Padding="20,16" Width="840">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.25" Color="#000000"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Personnes -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="👥  Nombre de personnes" FontFamily="{StaticResource AppFont}"
                                           FontSize="11" Foreground="#888888" Margin="0,0,0,6" FontWeight="SemiBold"/>
                                <Border Background="#F8F9FF" CornerRadius="8" Padding="12,8">
                                    <TextBox x:Name="TxtPersonnes" Style="{StaticResource SearchFieldStyle}"
                                             Tag="ex: 20" Text="ex: 20"
                                             GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                                </Border>
                            </StackPanel>

                            <!-- Séparateur -->
                            <Rectangle Grid.Column="1" Fill="#EEEEEE" Width="1" Margin="0,4"/>

                            <!-- Type -->
                            <StackPanel Grid.Column="2" Margin="16,0">
                                <TextBlock Text="🏛️  Type de salle" FontFamily="{StaticResource AppFont}"
                                           FontSize="11" Foreground="#888888" Margin="0,0,0,6" FontWeight="SemiBold"/>
                                <Border Background="#F8F9FF" CornerRadius="8" Padding="4,4">
                                    <ComboBox x:Name="CmbType" FontFamily="{StaticResource AppFont}"
                                              FontSize="13" BorderThickness="0" Background="Transparent"
Foreground="Black">
                                        <ComboBoxItem Content="Tous les types" IsSelected="True"/>
                                        <ComboBoxItem Content="Salle de réunion"/>
                                        <ComboBoxItem Content="Salle de cours"/>
                                        <ComboBoxItem Content="Amphithéâtre"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>

                            <!-- Bouton -->
                            <Button Grid.Column="3" Content="Rechercher" Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="24,12" Click="BtnRechercher_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- SECTION SALLES -->
            <Border Background="{StaticResource BgPrimaryBrush}" CornerRadius="24,24,0,0"
                    Margin="0,-20,0,0" Padding="32,32,32,48">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24" VerticalAlignment="Center">
                        <TextBlock Text="Nos salles disponibles" FontFamily="{StaticResource AppFont}"
                                   FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border x:Name="BadgeResultats" Background="#142045" CornerRadius="12"
                                Padding="10,4" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtResultats" FontFamily="{StaticResource AppFont}"
                                       FontSize="12" Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                    </StackPanel>
                    <WrapPanel x:Name="SallesPanel" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
