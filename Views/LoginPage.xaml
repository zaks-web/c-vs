<Page x:Class="GantsPlace.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgDeepBrush}" Title="Connexion">
    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1C2030" Offset="0"/>
                    <GradientStop Color="#151821" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush><SolidColorBrush Color="#252D45"/></Border.BorderBrush>
            <Border.BorderThickness><Thickness>1</Thickness></Border.BorderThickness>
            <Border.CornerRadius><CornerRadius>20</CornerRadius></Border.CornerRadius>
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="40" Opacity="0.4" Color="#000000"/>
            </Border.Effect>
            <StackPanel Margin="40">
                <!-- En-tête -->
                <Border Background="{StaticResource AccentBrush}" CornerRadius="12" Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border.Effect><DropShadowEffect Color="#4F8EF7" ShadowDepth="0" BlurRadius="20" Opacity="0.5"/></Border.Effect>
                    <TextBlock Text="🔑" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Connexion" FontFamily="{StaticResource AppFont}" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Accédez à votre espace de réservation"
                           FontFamily="{StaticResource AppFont}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <!-- Champs -->
                <TextBlock Text="Email" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtEmail" Style="{StaticResource InputFieldStyle}" Margin="0,0,0,16"/>

                <TextBlock Text="Mot de passe" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="TxtMdp" Style="{StaticResource PasswordFieldStyle}" Margin="0,0,0,8"/>

                <!-- Message erreur -->
                <Border x:Name="ErrBorder" Background="#2A0D0D" BorderBrush="{StaticResource DangerBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock x:Name="TxtErreur" FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap"/>
                </Border>

                <Button Content="Se connecter" Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Stretch" Padding="0,14" Margin="0,8,0,0" Click="BtnConnexion_Click"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Pas encore de compte ? " FontFamily="{StaticResource AppFont}"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button x:Name="BtnVersInscription" Content="S'inscrire"
                            Background="Transparent" BorderThickness="0" Cursor="Cursors.Hand"
                            Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource AppFont}"
                            FontSize="13" Padding="0" Click="BtnVersInscription_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
