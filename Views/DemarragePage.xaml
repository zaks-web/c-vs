<Page x:Class="GantsPlace.Views.DemarragePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgDeepBrush}" Title="Démarrage">
    <Grid>
        <!-- Fond dégradé -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F1117" Offset="0"/>
                    <GradientStop Color="#0D1830" Offset="0.5"/>
                    <GradientStop Color="#0F1117" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <!-- Cercles décoratifs -->
        <Ellipse Width="500" Height="500" HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-150,-150,0,0" Opacity="0.04">
            <Ellipse.Fill>
                <RadialGradientBrush><GradientStop Color="#4F8EF7" Offset="0"/><GradientStop Color="Transparent" Offset="1"/></RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="600" Height="600" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-200,-200" Opacity="0.04">
            <Ellipse.Fill>
                <RadialGradientBrush><GradientStop Color="#2ECC71" Offset="0"/><GradientStop Color="Transparent" Offset="1"/></RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <!-- Logo -->
                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0">
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="20"
                            Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect Color="#4F8EF7" ShadowDepth="0" BlurRadius="30" Opacity="0.6"/>
                        </Border.Effect>
                        <TextBlock Text="G" FontSize="38" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontFamily="{StaticResource AppFont}"/>
                    </Border>
                    <TextBlock Text="GANDS PLACE" FontFamily="{StaticResource AppFont}"
                               FontSize="42" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Réservation de salles à Lomé, Togo"
                               FontFamily="{StaticResource AppFont}" FontSize="16"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Séparateur -->
                <Rectangle Height="1" Width="120" Fill="{StaticResource BorderBrush_}"
                           HorizontalAlignment="Center" Margin="0,36,0,36"/>

                <!-- Équipe -->
                <TextBlock Text="Notre équipe" FontFamily="{StaticResource AppFont}"
                           FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <StackPanel x:Name="MembresPanel" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,0,0,48">
                    <!-- Les membres sont ajoutés dynamiquement dans le code-behind -->
                </StackPanel>

                <!-- Bouton entrer -->
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,0,0,60">
                    <Button x:Name="BtnEntrer" Content="Entrer dans l'application  →"
                            Style="{StaticResource PrimaryButtonStyle}"
                            FontSize="16" Padding="36,16"
                            Click="BtnEntrer_Click"/>
                </StackPanel>

                <!-- Stats rapides -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,60">
                    <Border Background="#1C2030" CornerRadius="12" Padding="24,16" Margin="8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="20" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Salles disponibles" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1C2030" CornerRadius="12" Padding="24,16" Margin="8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="3" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}"
                                       HorizontalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="Types de salles" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1C2030" CornerRadius="12" Padding="24,16" Margin="8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="100%" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}"
                                       HorizontalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                            <TextBlock Text="En ligne 24h/24" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" FontFamily="{StaticResource AppFont}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
