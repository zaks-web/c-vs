<Page x:Class="GantsPlace.Views.ContactPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgPrimaryBrush}" Title="Contact">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- HERO -->
            <Border Padding="40,36,40,32">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A1428" Offset="0"/>
                        <GradientStop Color="#0F1A35" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <TextBlock Text="Nous contacter"
                               FontFamily="{StaticResource AppFont}" FontSize="30" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Notre équipe est disponible pour répondre à toutes vos questions."
                               FontFamily="{StaticResource AppFont}" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- CONTENU -->
            <Grid Margin="40,0,40,48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>

                <!-- Cartes infos -->
                <StackPanel Grid.Column="0" Margin="0,32,0,0">
                    <TextBlock Text="Informations de contact"
                               FontFamily="{StaticResource AppFont}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                    <!-- Email -->
                    <Border Style="{StaticResource CardStyle}" Padding="20,16" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#142045" CornerRadius="10" Width="44" Height="44"
                                    Margin="0,0,16,0">
                                <TextBlock Text="📧" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="EMAIL" FontFamily="{StaticResource AppFont}"
                                           FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="contact@gandsplace.com" FontFamily="{StaticResource AppFont}"
                                           FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="info@gandsplace.com" FontFamily="{StaticResource AppFont}"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Téléphone -->
                    <Border Style="{StaticResource CardStyle}" Padding="20,16" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#0D2A1A" CornerRadius="10" Width="44" Height="44"
                                    Margin="0,0,16,0">
                                <TextBlock Text="📞" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="TÉLÉPHONE" FontFamily="{StaticResource AppFont}"
                                           FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"
                                            Margin="0,0,0,4"/>
                                <TextBlock Text="+228 96 47 07 52" FontFamily="{StaticResource AppFont}"
                                           FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                <TextBlock Text="+229 52 52 69 95" FontFamily="{StaticResource AppFont}"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Adresse -->
                    <Border Style="{StaticResource CardStyle}" Padding="20,16" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#2A1A0D" CornerRadius="10" Width="44" Height="44"
                                    Margin="0,0,16,0">
                                <TextBlock Text="📍" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="ADRESSE" FontFamily="{StaticResource AppFont}"
                                           FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"
                                            Margin="0,0,0,4"/>
                                <TextBlock Text="Lomé — TOGO 🇹🇬" FontFamily="{StaticResource AppFont}"
                                           FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Horaires -->
                    <Border Style="{StaticResource CardStyle}" Padding="20,16">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#1A1030" CornerRadius="10" Width="44" Height="44"
                                    Margin="0,0,16,0">
                                <TextBlock Text="🕐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="HORAIRES" FontFamily="{StaticResource AppFont}"
                                           FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"
                                            Margin="0,0,0,4"/>
                                <TextBlock Text="Lun-Ven : 8h00 – 20h00" FontFamily="{StaticResource AppFont}"
                                           FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Samedi : 9h00 – 18h00" FontFamily="{StaticResource AppFont}"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Équipe -->
                    <Border Style="{StaticResource CardStyle}" Padding="20,18" Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="Notre équipe" FontFamily="{StaticResource AppFont}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,14"/>
                            <StackPanel x:Name="TeamPanel" Orientation="Horizontal" Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Formulaire -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="28" Margin="0,32,0,0"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <!-- Titre formulaire -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Width="36" Height="36" Margin="0,0,12,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#4F8EF7" ShadowDepth="0" BlurRadius="12" Opacity="0.5"/>
                                </Border.Effect>
                                <TextBlock Text="✉️" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Envoyer un message"
                                           FontFamily="{StaticResource AppFont}" FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Réponse sous 24h"
                                           FontFamily="{StaticResource AppFont}" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Nom -->
                        <TextBlock Text="Nom complet" FontFamily="{StaticResource AppFont}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtNom" Style="{StaticResource InputFieldStyle}" Margin="0,0,0,16"/>

                        <!-- Email -->
                        <TextBlock Text="Adresse email" FontFamily="{StaticResource AppFont}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtEmail" Style="{StaticResource InputFieldStyle}" Margin="0,0,0,16"/>

                        <!-- Sujet -->
                        <TextBlock Text="Sujet" FontFamily="{StaticResource AppFont}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <Border Background="#1C2030" CornerRadius="8" BorderBrush="{StaticResource BorderBrush_}"
                                BorderThickness="1" Margin="0,0,0,16" Padding="4,2">
                            <ComboBox x:Name="CmbSujet" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                                      FontFamily="{StaticResource AppFont}" FontSize="13" BorderThickness="0">
                                <ComboBoxItem Content="Réservation" IsSelected="True"/>
                                <ComboBoxItem Content="Information générale"/>
                                <ComboBoxItem Content="Partenariat"/>
                                <ComboBoxItem Content="Problème technique"/>
                                <ComboBoxItem Content="Autre"/>
                            </ComboBox>
                        </Border>

                        <!-- Message -->
                        <TextBlock Text="Message" FontFamily="{StaticResource AppFont}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <Border Background="#1C2030" CornerRadius="8" BorderBrush="{StaticResource BorderBrush_}"
                                BorderThickness="1" Margin="0,0,0,20">
                            <TextBox x:Name="TxtMessage" MinHeight="110" Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     FontFamily="{StaticResource AppFont}" FontSize="13"
                                     BorderThickness="0" Padding="14,12"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     CaretBrush="{StaticResource AccentBrush}"/>
                        </Border>

                        <!-- Message retour -->
                        <Border x:Name="MsgBorder" CornerRadius="8" Padding="14,10"
                                Margin="0,0,0,14" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="MsgIcon" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtMsg" FontFamily="{StaticResource AppFont}" FontSize="13"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Bouton -->
                        <Button Content="Envoyer le message" Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Stretch" Padding="0,14"
                                Click="BtnEnvoyer_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
