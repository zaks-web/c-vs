<Page x:Class="GantsPlace.Views.DetailSallePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgPrimaryBrush}" Title="Détail Salle">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,32,40,48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- COLONNE GAUCHE : infos salle -->
            <StackPanel Grid.Column="0">
                <!-- Photo principale -->
                <Border x:Name="ImgBorder" Height="360" CornerRadius="16" ClipToBounds="True"
                        Background="{StaticResource BgCardBrush}">
                    <Border.Effect><DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.3" Color="#000000"/></Border.Effect>
                    <Grid>
                        <Border x:Name="ImgPlaceholder" Background="#1C2030">
                            <TextBlock x:Name="ImgIcon" FontSize="72" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Nom et type -->
                <StackPanel Margin="0,24,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border x:Name="TypeBadge" CornerRadius="6" Padding="10,5">
                            <TextBlock x:Name="TxtType" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TxtNom" FontFamily="{StaticResource AppFont}" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="👥" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtCapacite" FontFamily="{StaticResource AppFont}" FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtDescription" FontFamily="{StaticResource AppFont}" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" LineHeight="22"/>
                </StackPanel>

                <!-- Équipements -->
                <StackPanel Margin="0,24,0,0">
                    <TextBlock Text="Équipements disponibles" FontFamily="{StaticResource AppFont}"
                               FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>
                    <WrapPanel x:Name="EquipPanel"/>
                </StackPanel>
            </StackPanel>

            <!-- COLONNE DROITE : formulaire réservation -->
            <Border Grid.Column="2" Background="{StaticResource BgCardBrush}" CornerRadius="16"
                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush_}"
                    VerticalAlignment="Top" Padding="28">
                <Border.Effect><DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.3" Color="#000000"/></Border.Effect>
                <StackPanel x:Name="ReservPanel">
                    <TextBlock Text="Réserver cette salle" FontFamily="{StaticResource AppFont}"
                               FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,20"/>

                    <!-- Panel connecté -->
                    <StackPanel x:Name="PanelConnecte" Visibility="Collapsed">
                        <TextBlock Text="Date" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <DatePicker x:Name="DpDate" Margin="0,0,0,16"
                                    Background="#1C2030" Foreground="{StaticResource TextPrimaryBrush}"
                                    FontFamily="{StaticResource AppFont}" FontSize="13"
                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush_}"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Heure début" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbDebut" FontFamily="{StaticResource AppFont}" FontSize="13"
                                          Background="#1C2030" Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderThickness="1" BorderBrush="{StaticResource BorderBrush_}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Heure fin" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbFin" FontFamily="{StaticResource AppFont}" FontSize="13"
                                          Background="#1C2030" Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderThickness="1" BorderBrush="{StaticResource BorderBrush_}"/>
                            </StackPanel>
                        </Grid>

                        <Border x:Name="MsgBorder" CornerRadius="8" Padding="12,8" Margin="0,0,0,12" Visibility="Collapsed">
                            <TextBlock x:Name="TxtMsg" FontFamily="{StaticResource AppFont}" FontSize="13" TextWrapping="Wrap"/>
                        </Border>

                        <Button Content="✓  Enregistrer la réservation" Style="{StaticResource ReservationButtonStyle}"
                                HorizontalAlignment="Stretch" Click="BtnReserver_Click"/>
                    </StackPanel>

                    <!-- Panel non connecté -->
                    <StackPanel x:Name="PanelNonConnecte" Visibility="Collapsed">
                        <Border Background="#1A1430" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="🔒" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Connectez-vous pour réserver cette salle."
                                           FontFamily="{StaticResource AppFont}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                           TextAlignment="Center" Margin="0,0,0,14"/>
                                <Button Content="Se connecter" Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Stretch" Click="BtnSeConnecter_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
