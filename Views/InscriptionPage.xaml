<Page x:Class="GantsPlace.Views.InscriptionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgDeepBrush}" Title="Inscription">
    <Grid>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="440"
                CornerRadius="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush_}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1C2030" Offset="0"/><GradientStop Color="#151821" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect><DropShadowEffect ShadowDepth="0" BlurRadius="40" Opacity="0.4" Color="#000000"/></Border.Effect>
            <StackPanel Margin="40">
                 <Image Source="/Images/logo.png" Width="100" Height="100" Stretch="Uniform">
                                <Image.Effect>
                                    <DropShadowEffect Color="#4F8EF7" ShadowDepth="0" BlurRadius="30" Opacity="0.6"/>
                                </Image.Effect>
                            </Image>
                <TextBlock Text="Créer un compte" FontFamily="{StaticResource AppFont}" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Rejoignez GANDS RESERVATION et réservez vos salles"
                           FontFamily="{StaticResource AppFont}" FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <TextBlock Text="Nom complet" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtNom" Style="{StaticResource InputFieldStyle}" Margin="0,0,0,14"/>

                <TextBlock Text="Email" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtEmail" Style="{StaticResource InputFieldStyle}" Margin="0,0,0,14"/>

                <TextBlock Text="Mot de passe" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="TxtMdp" Style="{StaticResource PasswordFieldStyle}" Margin="0,0,0,14"/>

                <TextBlock Text="Confirmer le mot de passe" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="TxtMdp2" Style="{StaticResource PasswordFieldStyle}" Margin="0,0,0,12"/>

                <Border x:Name="MsgBorder" CornerRadius="8" Padding="12,8" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock x:Name="TxtMsg" FontFamily="{StaticResource AppFont}" FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <Button Content="Créer mon compte" Style="{StaticResource ReservationButtonStyle}"
                        HorizontalAlignment="Stretch" Padding="0,14" Margin="0,4,0,0" Click="BtnInscrire_Click"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <TextBlock Text="Déjà un compte ? " FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Button Content="Se connecter" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource AppFont}"
                            FontSize="13" Padding="0" Click="BtnVersLogin_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
